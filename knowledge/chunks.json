  {
    "id": "kb_7794ffba842db855",
    "title": "ECCC: ACL Anthology record",
    "content": "ECCC: Edge Code Cloak Coder for Privacy Code Agent is a WiNLP 2025 paper by Haoqi He, Wenzhi Xu, Ruoying Liu, Jiarui Tang, Bairu Li, and Xiaokai Lin, pages 65–74. It combines a lightweight local model, AST-based anonymization, edge-side privacy validation, and cloud delegation of abstracted tasks. The paper reports correctness within 4–5 percentage points of evaluated GPT-4-based frameworks and a 10/10 privacy score under its stated evaluation.",
    "evidenceType": "official_publication",
    "status": "peer_reviewed",
    "provenance": {
      "originFile": "knowledge/sources.json",
